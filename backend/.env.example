DEBUG=true
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
BATCH_SIZE=50
USE_SP500_UNIVERSE=true
PRICE_POLL_INTERVAL_SEC=60
SCAN_CRON_HOUR=6
SCAN_CRON_MINUTE=0
ORDER_HISTORY_CLEAR_HOUR=0
ORDER_HISTORY_CLEAR_MINUTE=0
ORDER_HISTORY_TIMEZONE=Asia/Bangkok
# Optional runtime path overrides (leave empty for auto-detect via platformdirs)
# Useful when project lives in a non-ASCII folder on Windows (e.g. Thai path)
# RUNTIME_DIR=C:/AppData/Local/us-swing-signals
# CACHE_DIR=C:/AppData/Local/us-swing-signals/cache
# YFINANCE_CACHE_DIR=C:/AppData/Local/us-swing-signals/yfinance
